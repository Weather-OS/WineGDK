#pragma makedep header

#ifdef __WIDL__
#pragma winrt ns_prefix
#endif

import "propidl.idl";
import "inspectable.idl";
import "asyncinfo.idl";
import "eventtoken.idl";
import "windowscontracts.idl";
import "windows.foundation.idl";
import "windows.foundation.collections.idl";
import "windows.storage.streams.idl";
import "windows.system.idl";

// --- xgameruntime --- //

namespace Xodus
{    
    typedef struct TitleMgtSignaturePolicy TitleMgtSignaturePolicy;

    typedef enum MagicHeaderType MagicHeaderType;

    interface IIPCLayer;
    interface IXodusService;
    interface IXodusIPCPacket;
    interface IXodusXMLBuilder;
    interface IXstsTokenResponse;

    runtimeclass IPCLayer;
    runtimeclass XodusXMLBuilder;
    runtimeclass XodusService;

    struct TitleMgtSignaturePolicy
    {
        Windows.Foundation.Collections.IVectorView<HSTRING> *SupportedAlgorithms;
        UINT64 MaxBodyBytes;
        Windows.Foundation.Collections.IVectorView<HSTRING> *SupportedSignatureTypes;
    };

    declare 
    {
        interface Windows.Foundation.AsyncOperationCompletedHandler<Xodus.IXodusIPCPacket *>;
        interface Windows.Foundation.IAsyncOperation<Xodus.IXodusIPCPacket *>;
        interface Windows.Foundation.AsyncOperationCompletedHandler<Xodus.IXstsTokenResponse *>;
        interface Windows.Foundation.IAsyncOperation<Xodus.IXstsTokenResponse *>;
    }

    [
        contract(Windows.Foundation.UniversalApiContract, 1.0)
    ]
    enum MagicHeaderType
    {
        XML = 0x58445358,
        Proto = 0x58445350,
    };

    [
        uuid(e5670e5d-a32e-47e0-91c6-12163115072b)
    ]    
    delegate HRESULT IPCResponseHandler( IXodusIPCPacket *reponse );

    [
        uuid(fb150d06-cbf2-4a66-9401-57bcbef19068)
    ]
    interface IXodusIPCPacket : IUnknown
    {
        [propget] HRESULT Magic( [out, retval] MagicHeaderType *out );
        [propget] HRESULT MessageType( [out, retval] UINT16 *out );
        [propget] HRESULT Message( [out, retval] Windows.Storage.Streams.IBuffer **out );
    }

    [
        uuid(f7904b4d-4738-4485-a517-b37405aa5b91)
    ]
    interface IIPCLayer : IInspectable
    {
        HRESULT InitializeSocket();
        HRESULT SendRequestAsync( [in] Xodus.IXodusIPCPacket *packet, [out, retval] Windows.Foundation.IAsyncOperation<Xodus.IXodusIPCPacket *> **operation );
        [eventadd] HRESULT ResponseReceived( [in] Xodus.IPCResponseHandler *handler, [out, retval] EventRegistrationToken *token );
        [eventremove] HRESULT ResponseReceived( [in] EventRegistrationToken token );
    }

    [
        uuid(852d70bb-c6de-447a-8082-61646691295e)
    ]
    interface IXodusService : IInspectable
    {
        HRESULT Ping( [out, retval] Windows.Foundation.IAsyncAction **operation );
        HRESULT XstsTokenRequest( [in] HSTRING url, [out, retval] Windows.Foundation.IAsyncOperation<Xodus.IXstsTokenResponse *> **operation );
    }

    [
        uuid(7f70954e-1d3b-4d44-ab18-e43add94657c)
    ]
    interface IXodusXMLBuilder : IInspectable
    {
        HRESULT BuildXstsTokenRequestXml( [in] HSTRING url, [out, retval] LPSTR *xml_string );
        HRESULT FromXstsTokenResponseXml( [in] LPCSTR xml_string, [out, retval] IXstsTokenResponse **response );
    }

    [
        uuid(8b604b41-434b-40a0-b62e-155c3ec3194c)
    ]
    interface IXstsTokenResponse : IUnknown
    {
        [propget] HRESULT UserToken( [out, retval] HSTRING *out );
        [propget] HRESULT Expiry( [out, retval] Windows.Foundation.DateTime *out );
        [propget] HRESULT RelyingParty( [out, retval] HSTRING *out );
        [propget] HRESULT SignaturePolicy( [out, retval] TitleMgtSignaturePolicy *out );
    }

    [
        contract(Windows.Foundation.UniversalApiContract, 1.0)
    ]
    runtimeclass XodusService
    {
        [default] interface Xodus.IXodusService;
    }

    [
        contract(Windows.Foundation.UniversalApiContract, 1.0)
    ]
    runtimeclass XodusXMLBuilder
    {
        [default] interface Xodus.IXodusXMLBuilder;
    }

    [
        contract(Windows.Foundation.UniversalApiContract, 1.0)
    ]
    runtimeclass IPCLayer
    {
        [default] interface Xodus.IIPCLayer;
    }
}